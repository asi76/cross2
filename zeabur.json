{
  "build": {
    "command": "npm install && npm run build",
    "development": "npm run dev",
    "framework": "node"
  },
  "start": {
    "command": "node server/index.js",
    "env": {
      "NODE_ENV": "production"
    }
  },
  "routes": {
    "/": {
      "use": "server/index.js"
    }
  },
  "env": {
    "GITHUB_TOKEN": {
      "description": "GitHub Personal Access Token"
    },
    "GITHUB_REPO": {
      "description": "GitHub repository (default: asi76/crosstraining)"
    }
  }
}

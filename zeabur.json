{
  "build": {
    "command": "npm run build",
    "development": "npm run dev",
    "framework": "node"
  },
  "routes": {
    "/": {
      "path": "dist/index.html",
      "headers": {
        "Content-Type": "text/html"
      }
    }
  },
  "env": {
    "NODE_ENV": {
      "value": "production"
    },
    "GITHUB_TOKEN": {
      "description": "GitHub Personal Access Token for auto-committing GIFs"
    },
    "GITHUB_REPO": {
      "description": "GitHub repository (default: asi76/crosstraining)"
    }
  }
}

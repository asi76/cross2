# Google OAuth2 Credentials
# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth2callback

# Google Drive Folder ID (where GIFs will be uploaded)
# The folder path or ID for /apps/crosstraining/gif
DRIVE_FOLDER_ID=1YRIKZ5HPL76KDOPPzbOt2qIWrlRoGHL0
DRIVE_GIFS_FOLDER_ID=apps/crosstraining/gif

# OAuth2 Tokens (set after first authentication)
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=

# Server port
PORT=3001
